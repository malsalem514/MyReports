# Copy to .env.e2e and fill real values

# App/Auth
AUTH_SECRET=replace-with-long-random-secret
NEXTAUTH_URL=http://localhost:3001
DEV_BYPASS_AUTH=false
DEV_BYPASS_EMAIL=

# Azure Entra SSO (required when DEV_BYPASS_AUTH=false)
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# Oracle
ORACLE_USER=timelogs
ORACLE_PASSWORD=
ORACLE_CONNECT_STRING=srv-db-100/suppops
# For Docker host mapping (container DNS fix)
ORACLE_DB_HOST=srv-db-100
ORACLE_DB_IP=172.16.25.63

# BigQuery
BIGQUERY_PROJECT_ID=us-activtrak-ac-prod
BIGQUERY_DATASET=672561
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/google-sa.json
# Host path used by docker-compose bind mount
GOOGLE_SA_JSON_PATH=/absolute/path/to/google-sa.json

# BambooHR
BAMBOOHR_API_KEY=
BAMBOOHR_SUBDOMAIN=jestais

# Runtime
ENABLE_SCHEDULER=false
